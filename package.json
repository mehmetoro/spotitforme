{
  "name": "spotitforme",
  "version": "0.1.0",
  "private": true,
  "description": "Toplulukla ürün bulma platformu",
  "author": "SpotItForMe Team",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:shop": "next build && echo 'Test sayfası hazır: http://localhost:3000/test/mağaza-kaydı'",
    "icon-192": "sharp public/spotitforme_icon.png -resize 192x192 public/icons/icon-192.png",
    "icon-512": "sharp public/spotitforme_icon.png -resize 512x512 public/icons/icon-512.png",
    "icon-maskable": "sharp public/spotitforme_icon.png -resize 512x512 public/icons/icon-maskable-512.png",
    "icon-apple": "sharp public/spotitforme_icon.png -resize 180x180 public/apple-touch-icon.png",
    "icons": "npm run icon-192 && npm run icon-512 && npm run icon-maskable && npm run icon-apple"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@heroicons/react": "^2.2.0",
    "@supabase/ssr": "^0.1.0",
    "@supabase/supabase-js": "^2.39.0",
    "@types/google.maps": "^3.58.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.309.0",
    "next": "14.0.4",
    "nodemailer": "^6.9.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^10.0.2",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.4",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/username/spotitforme"
  },
  "bugs": {
    "url": "https://github.com/username/spotitforme/issues"
  },
  "homepage": "https://spotitforme.com"
}
